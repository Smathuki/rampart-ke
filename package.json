{
  "name": "rampart-ke",
  "version": "0.1.0",
  "description": "Kenya-localized, on-device PII redaction. A thin wrapper around @nationaldesignstudio/rampart that adds deterministic recognizers for Kenyan identifiers (KRA PIN, M-Pesa, National ID, SHA/SHIF, NSSF, phone, company names, locations) before any data leaves the device.",
  "type": "module",
  "license": "CC-BY-4.0",
  "keywords": ["pii", "redaction", "privacy", "kenya", "data-protection", "on-device", "rampart"],
  "homepage": "https://github.com/Smathuki/rampart-ke#readme",
  "repository": { "type": "git", "url": "git+https://github.com/Smathuki/rampart-ke.git" },
  "bugs": { "url": "https://github.com/Smathuki/rampart-ke/issues" },
  "engines": { "node": ">=18" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "demo:build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@nationaldesignstudio/rampart": "^0.1.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
